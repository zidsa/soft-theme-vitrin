{#
  Products Carousel Component

  Props:
  - products: array of Product objects
  - title: string (optional) - section title
  - more_url: string (optional) - URL for "View all" link
  - more_text: string (optional) - text for "View all" link
  - carousel_id: string (optional) - unique ID for the carousel
  - slides_mobile: number (optional, default 1) - slides shown below 768px
  - slides_tablet: number (optional, default 2) - slides shown between 768px and 991px
  - slides_desktop: number (optional, default 3) - slides shown at 992px and above
#}

{% set carousel_id = carousel_id or 'product-slider-' ~ range(1000, 9999) | random %}
{% set slides_mobile = slides_mobile if slides_mobile is defined else 1 %}
{% set slides_tablet = slides_tablet if slides_tablet is defined else 2 %}
{% set slides_desktop = slides_desktop if slides_desktop is defined else 3 %}

{% if products and products | length > 0 %}
  <section class="mt-5 mb-5">
    <div class="d-flex align-items-center mb-4">
      {% if title %}
      <div class="product-slider-icon" style="font-size: 24px; height: 24px">
        <span class="icon-uniE011"></span>
      </div>
      <div class="product-slider-title">
        <div class="">{{ title }}</div>
      </div>
    </div>
    {% endif %}
    <div class="product-slider-paragrah">
      <div class="">
        <div class="products-slider-wrapper" style="position: relative">

          <div id="{{ carousel_id }}" class="products-slider s-slider loading d-block">
            {% for rProduct in products %}
              <div class="prod-col">
                {% set product=rProduct %}{% set index=loop.index0 %}
                {% include 'components/product-card.jinja' %}
              </div>
            {% endfor %}
          </div>

        </div>
      </div>
    </div>
  </section>
  <script>
    window.addEventListener("load", function () {
      var $slider = $('#{{ carousel_id }}');

      if (!$slider.length || $slider.hasClass('slick-initialized')) {
        $slider.removeClass('loading');
        return;
      }
      var arrowNextClass, arrowPrevClass;
      if (window.appDirection === 'ltr') {
        arrowNextClass = 'icon-keyboard_arrow_right';
        arrowPrevClass = 'icon-keyboard_arrow_left';
      } else {
        arrowNextClass = 'icon-keyboard_arrow_left';
        arrowPrevClass = 'icon-keyboard_arrow_right';
      }

      $slider.slick({
        slidesToShow: {{ slides_desktop }},
        slidesToScroll: 1,
        infinite: false,
        arrows: false,
        dots: false,
        rtl: !(window.appDirection === 'ltr'),
        responsive: [
          {
            breakpoint: 768,
            settings: {
              slidesToShow: {{ slides_mobile }},
              arrows: false
            }
          },
          {
            breakpoint: 992,
            settings: {
              slidesToShow: {{ slides_tablet }},
              arrows: true,
              nextArrow: '<button class="slick-next slick-arrow" type="button"><span class="' + arrowNextClass + '"></span></button>',
              prevArrow: '<button class="slick-prev slick-arrow" type="button"><span class="' + arrowPrevClass + '"></span></button>'
            }
          },
          {
            breakpoint: 99999, // desktop fallback
            settings: {
              slidesToShow: {{ slides_desktop }},
              arrows: true,
              nextArrow: '<button class="slick-next slick-arrow" type="button"><span class="' + arrowNextClass + '"></span></button>',
              prevArrow: '<button class="slick-prev slick-arrow" type="button"><span class="' + arrowPrevClass + '"></span></button>'
            }
          }
        ]
      });
      $slider.removeClass('loading');
    });
    $(window).on('resize', function () {
      if ($('#{{ carousel_id }}').hasClass('slick-initialized')) {
        $('#{{ carousel_id }}').slick('setPosition');
      }
    });
  </script>
{% endif %}
