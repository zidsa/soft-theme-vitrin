{# Blog Card Component (Bootstrap 4.1.3 version) #}

{% set blog_description = blog.snippet | default(none) %}
{% set blog_image = blog.cover.image.medium if blog.cover and blog.cover.image else none %}
{% set blog_date = blog.published_at | default(none) %}
{% set blog_category = blog.category if blog.category else none %}
{% set all_tags = blog.tags | default([]) %}

{% set max_visible_badges = 4 %}
{% set ns = namespace(badges=[]) %}

{% if blog_category %}
  {% set ns.badges = ns.badges + [{'name': blog_category.name, 'is_category': true}] %}
{% endif %}

{% for tag in all_tags %}
  {% set ns.badges = ns.badges + [{'name': tag.name, 'is_category': false}] %}
{% endfor %}

{% set visible_badges = ns.badges[:max_visible_badges] %}
{% set remaining_count = ns.badges | length - max_visible_badges %}

<article class="h-100 d-flex flex-column blog-card position-relative border">

  {# Click overlay #}
  <a href="/blogs/{{ blog.slug }}" class="blog-overlay-link" aria-label="{{ blog.title }}"></a>

  {# Image #}
  <div class="blog-image">
    {% if blog_image %}
      <img src="{{ blog_image }}" alt="{{ blog.title }}" loading="lazy">
    {% else %}
      <div class="d-flex align-items-center justify-content-center h-100 bg-light text-muted">
        <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24"
             fill="none" stroke="currentColor" stroke-width="1"
             stroke-linecap="round" stroke-linejoin="round">
          <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
          <circle cx="8.5" cy="8.5" r="1.5"></circle>
          <polyline points="21 15 16 10 5 21"></polyline>
        </svg>
      </div>
    {% endif %}
  </div>


  {# Content #}
  <div class="bg-light d-flex flex-column flex-grow-1 p-4">

    {# Title #}
    <h3 class="font-weight-bold text-uppercase blog-title mb-2">
      {{ blog.title }}
    </h3>

    {# Description #}
    {% if blog_description %}
      <p class="blog-desc mb-3">
        {{ blog_description | striptags | truncate(160) }}
      </p>
    {% endif %}

    {# Badges #}
    {% if ns.badges | length > 0 %}
      <div class="d-flex flex-wrap blog-badges mb-3">
        {% for badge in visible_badges %}
          <span class="badge-item {{ 'font-weight-bold' if badge.is_category }}">
            {{ badge.name }}
          </span>
        {% endfor %}

        {% if remaining_count > 0 %}
          <span class="badge-item text-muted border-0">
            +{{ remaining_count }}
          </span>
        {% endif %}
      </div>
    {% endif %}

    {# Footer #}
    <div class="mt-auto d-flex justify-content-between align-items-center pt-2">

      {% if blog_date %}
        <span class="text-muted small" data-blog-date="{{ blog_date }}">
          {{ blog_date }}
        </span>
      {% endif %}

      <span class="small font-weight-medium ml-auto d-inline-flex align-items-center">
        {{ _("Read more") }}
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16"
             viewBox="0 0 24 24" fill="none" stroke="currentColor"
             stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
             class="ml-1 blog-arrow">
          <path d="m9 18 6-6-6-6"></path>
        </svg>
      </span>

    </div>

  </div>
</article>